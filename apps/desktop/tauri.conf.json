{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoundWorks",
  "version": "0.1.0",
  "identifier": "com.sceneworks.soundworks",
  "build": {
    "beforeDevCommand": "npm run dev -w apps/web",
    "beforeBuildCommand": "npm run build -w apps/web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "SoundWorks",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
